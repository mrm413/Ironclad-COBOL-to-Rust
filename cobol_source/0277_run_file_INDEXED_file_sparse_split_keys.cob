/// MAINFILE
fn p_mainfile(state: &mut ProgramState) {
    p_loadfile(state);
    p_listfile(state);
    { let _ = state.tspfile_handle.close();
        std::process::exit(0); }
}

/// LOADFILE
fn p_loadfile(state: &mut ProgramState) {
    println!("{}{}{}", "Loading sample data file.", state.upon, state.console);
    tspfile_open_output(state);
    if state.cust_stat.as_str() != "00" {
        state.byte_1 = state.cust_stat.stat_1 / state.?missing?;
        state.byte_2 = state.cust_stat.stat_1 % state.?missing?;
        println!("{}{}{}{}{}{}{}{}{}", "Error ", state.cust_stat, " ", state.byte_1, " ", state.byte_2, " opening 'testisam' file", state.upon, state.console);
        { let _ = state.tspfile_handle.close();
            std::process::exit(0); }
    }
    p_1000_load_record(state);
}

/// MAX-SUB
fn p_max_sub(state: &mut ProgramState) {
    println!("{}{}{}", "Sample data file load complete.", state.upon, state.console);
    tspfile_close(state);
}

/// 1000-LOAD-RECORD
fn p_1000_load_record(state: &mut ProgramState) {
    state.tspfl_record = Default::default();
    state.cm_cust_num = FixedString::copy_from(&state.test_data.data_cust_num[((state.work_area.sub - 1) as usize).min(0)]);
    state.work_area.tspfl_key = FixedString::copy_from(&state.cm_cust_num);
    state.cm_company = FixedString::copy_from(&state.test_data.data_company[((state.work_area.sub - 1) as usize).min(0)]);
    state.cm_address_1 = FixedString::copy_from(&state.test_data.data_address_1[((state.work_area.sub - 1) as usize).min(0)]);
    state.cm_address_2 = FixedString::copy_from(&state.test_data.data_address_2[((state.work_area.sub - 1) as usize).min(0)]);
    state.cm_address_3 = FixedString::copy_from(&state.test_data.data_address_3[((state.work_area.sub - 1) as usize).min(0)]);
    state.cm_telephone = state.test_data.data_telephone[((state.work_area.sub - 1) as usize).min(0)];
    state.cm_dp_mgr = FixedString::copy_from(&state.test_data.data_dp_mgr[((state.work_area.sub - 1) as usize).min(0)]);
    state.cm_machine = FixedString::copy_from(&state.test_data.data_machine[((state.work_area.sub - 1) as usize).min(0)]);
    state.cm_no_terminals = state.test_data.data_no_terminals[((state.work_area.sub - 1) as usize).min(0)];
    if state.work_area.sub == "" {
        state.cm_disk = "8417".into();
        state.cm_tape = "1600 BPI".into();
        state.cm_memory = "1MEG".into();
    } else {
        state.cm_disk = "8470".into();
        state.cm_tape = "6250 BPI".into();
        state.cm_memory = "3MEG".into();
        if state.work_area.sub == "" {
            state.?missing? = state.all;
            state.to = state.all;
            state.cm_disk = state.all;
            state.?missing? = state.all;
            state.to = state.all;
            state.cm_tape = state.all;
            tspfl_record_write(state);
            if (state.cust_stat.as_str() != "00") && (state.cust_stat.as_str() != "02") {
                println!("{}{}{}{}{}{}", "Key: ", state.work_area.tspfl_key, ", Status: ", state.cust_stat, state.upon, state.console);
            }
        }
    }
}

/// LISTFILE
fn p_listfile(state: &mut ProgramState) {
    println!("{}{}{}", "LIST SAMPLE FILE", state.upon, state.console);
    state.work_area.rec_num = Default::default();
    tspfile_open_input(state);
    if state.cust_stat.as_str() != "00" {
        println!("{}{}{}{}{}", "ERROR ", state.cust_stat, " OPENING INPUT FILE ", state.upon, state.console);
        if std::str::from_utf8(&state.cust_stat.as_bytes()[(1 - 1) as usize..(1 - 1 + 1) as usize]).unwrap_or("").as_str() == "9" {
            println!("{}{}{}{}", "Sub Error ", state.stat_x2, state.upon, state.console);
        }
        { let _ = state.tspfile_handle.close();
            std::process::exit(0); }
    }
    state.tspfl_record = Default::default();
    // START TSPFILE
    tspfile_read(state);
    if state.cust_stat.as_str() != "00" {
        println!("{}{}{}{}{}", "Error ", state.cust_stat, " on 1st read of file", state.upon, state.console);
        if std::str::from_utf8(&state.cust_stat.as_bytes()[(1 - 1) as usize..(1 - 1 + 1) as usize]).unwrap_or("").as_str() == "9" {
            println!("{}{}{}{}", "Sub Error ", state.stat_x2, state.upon, state.console);
        }
        { let _ = state.tspfile_handle.close();
            std::process::exit(0); }
    }
    p_until(state);
    println!("{}{}{}{}{}{}{}{}{}", "Key: ", state.cm_cust_num, " is ", state.cm_company, " Disk=", state.cm_disk, ":", state.upon, state.console);
    tspfile_read(state);
