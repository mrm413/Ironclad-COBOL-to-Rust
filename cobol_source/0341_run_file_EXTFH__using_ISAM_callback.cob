            if _len > 59 { let _end = _len.min(59+25); state.ts_address_2 = FixedString::from(String::from_utf8_lossy(&_bytes[59.._end])); }
            if _len > 84 { let _end = _len.min(84+25); state.ts_address_3 = FixedString::from(String::from_utf8_lossy(&_bytes[84.._end])); }
            if _len > 109 { let _end = _len.min(109+10); let _s = String::from_utf8_lossy(&_bytes[109.._end]).trim().to_string(); state.ts_telephone = _s.parse().unwrap_or_default(); }
            if _len > 119 { let _end = _len.min(119+25); state.ts_dp_mgr = FixedString::from(String::from_utf8_lossy(&_bytes[119.._end])); }
            if _len > 144 { let _end = _len.min(144+8); state.ts_machine = FixedString::from(String::from_utf8_lossy(&_bytes[144.._end])); }
            if _len > 152 { let _end = _len.min(152+4); state.ts_memory = FixedString::from(String::from_utf8_lossy(&_bytes[152.._end])); }
            if _len > 156 { let _end = _len.min(156+8); state.ts_disk = FixedString::from(String::from_utf8_lossy(&_bytes[156.._end])); }
            if _len > 164 { let _end = _len.min(164+8); state.ts_tape = FixedString::from(String::from_utf8_lossy(&_bytes[164.._end])); }
            state.tstfile_status = FileStatus::Success;
    state.cust_stat = match &state.tstfile_status { FileStatus::Success => FixedString::from("00"), FileStatus::AtEnd => FixedString::from("10"), FileStatus::Error(c) => FixedString::from(c.as_str()), };
        }
