fn tstfile_read(state: &mut ProgramState) -> Result<(), FileStatus> {
    match state.tstfile_handle.read_line() {
        Ok(line) => {
            let _bytes = line.as_bytes();
            let _len = _bytes.len().min(172);
            if _len > 0 { let _end = _len.min(0+172); state.tstfl_record = FixedString::from(String::from_utf8_lossy(&_bytes[0.._end])); }
            if _len > 0 { let _end = _len.min(0+172); state.tstfl_rec = FixedString::from(String::from_utf8_lossy(&_bytes[0.._end])); }
            if _len > 0 { let _end = _len.min(0+8); state.ts_cust_num = FixedString::from(String::from_utf8_lossy(&_bytes[0.._end])); }
            if _len > 8 { let _end = _len.min(8+1); state.ts_status = FixedString::from(String::from_utf8_lossy(&_bytes[8.._end])); }
            if _len > 9 { let _end = _len.min(9+25); state.ts_company = FixedString::from(String::from_utf8_lossy(&_bytes[9.._end])); }
