    p_loadfile(state);
    p_listfile(state);
    tstfile_open_input(state);
    if state.cust_stat.as_str() != "00" {
        println!("{}{}{}{}{}", "Expected ERROR ", state.cust_stat, " opening TSTFILE, Record size different", state.upon, state.console);
